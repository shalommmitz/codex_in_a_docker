#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path
import sys, os

REPO_ROOT = Path(__file__).resolve().parent
EXCLUDED_DIRS = {"__pycache__", "code", "tmp"}


def list_candidate_folders() -> list[Path]:
    folders: list[Path] = []
    for path in sorted(REPO_ROOT.iterdir()):
        if not path.is_dir():
            continue
        if path.name.startswith("."):
            continue
        if path.name in EXCLUDED_DIRS:
            continue
        folders.append(path)
    return folders


def remove_existing_code_path(code_path: Path) -> None:
    if not code_path.exists() and not code_path.is_symlink():
        return

    if code_path.is_symlink():
        code_path.unlink()
        return

    if code_path.is_dir():
        try:
            code_path.rmdir()
        except OSError:
            print("Refusing to replace './code' because it is a non-empty directory.", file=sys.stderr)
            print("Move it aside or empty it, then run this script again.", file=sys.stderr)
            raise SystemExit(1)
        return

    print("Refusing to replace './code' because it is not a directory or symlink.", file=sys.stderr)
    raise SystemExit(1)


def main() -> int:
    folders = list_candidate_folders()
    if not folders:
        print("No project folders found. Create a sibling folder first.", file=sys.stderr)
        return 1

    print("Select the active folder:")
    for idx, folder in enumerate(folders):
        print(f"  {idx}: {folder.name}")

    answer = input("Enter the number of the folder to link as './code': ").strip()
    if not answer.isdigit():
        print("Selection must be a number.", file=sys.stderr)
        return 1

    selected_index = int(answer)
    if selected_index < 0 or selected_index >= len(folders):
        print("Selection is out of range.", file=sys.stderr)
        return 1

    selected_folder = folders[selected_index]
    code_path = REPO_ROOT / "code"
    remove_existing_code_path(code_path)
    code_path.symlink_to(selected_folder.name)

    print(f"'./code' now points to '{selected_folder.name}'.")
    print("Restarting the container, to activate the change .")
    os.system("./stop_docker")
    os.system("./build_docker")
    os.system("./run_docker")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
